# MISTRAL_API_KEY: Required for Mistral AI (Codestral) API calls.
# Get your key from https://console.mistral.ai/
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AURA_API_KEY: Secure token to access the Aura-AI custom completions backend.
AURA_API_KEY="aura-token-2026"

# EXA_API_KEY: Optional Exa.ai semantic web search API key to replace or augment search grounding.
# Get your key from https://dashboard.exa.ai/
EXA_API_KEY="YOUR_EXA_API_KEY_HERE"

